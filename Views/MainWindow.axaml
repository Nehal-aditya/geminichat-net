<Window xmlns="https://github.com/avaloniaui"
        Icon="avares://GeminiChat/Assets/app.ico"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GeminiChat.ViewModels"
        xmlns:m="clr-namespace:GeminiChat.Models"
        xmlns:cv="clr-namespace:GeminiChat.Converters"
        xmlns:ctrl="clr-namespace:GeminiChat.Controls"
        x:Class="GeminiChat.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Gemini Chat"
        Width="1300" Height="820"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackground}">

  <Window.Resources>
    <cv:BoolToVisConverter         x:Key="BoolVis"/>
    <cv:InverseBoolConverter       x:Key="InvBool"/>
    <cv:RoleToAlignConverter       x:Key="RoleAlign"/>
    <cv:RoleToBubbleBrushConverter x:Key="RoleBubble"/>
    <cv:RoleToTextBrushConverter   x:Key="RoleText"/>
    <cv:ApiKeyValidColorConverter  x:Key="KeyColor"/>
    <cv:DateTimeConverter          x:Key="DateFmt"/>
    <cv:IsUserToAvatarTextConverter x:Key="AvatarText"/>
    <cv:IsUserToAvatarBrushConverter x:Key="AvatarBrush"/>
    <cv:StatusToColorConverter     x:Key="StatusColor"/>
    <cv:IntToVisConverter          x:Key="IntVis"/>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
      <Setter Property="FontFamily" Value="Inter, Segoe UI, sans-serif"/>
    </Style>
    
    <Style Selector="TextBox">
      <Setter Property="Background"   Value="{DynamicResource GlassBg}"/>
      <Setter Property="Foreground"   Value="{DynamicResource MainText}"/>
      <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding"      Value="12,10"/>
      <Setter Property="CaretBrush"   Value="{DynamicResource NeonAccent}"/>
    </Style>
    <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
      <Setter Property="BorderBrush" Value="{DynamicResource NeonAccent}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style Selector="Button.primary">
      <Setter Property="Background"   Value="{DynamicResource AccentColor}"/>
      <Setter Property="Foreground"   Value="White"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding"      Value="16,10"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Cursor"       Value="Hand"/>
      <Setter Property="FontWeight"   Value="SemiBold"/>
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.2"/>
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource NeonAccent}"/>
    </Style>

    <Style Selector="Button.ghost">
      <Setter Property="Background"      Value="Transparent"/>
      <Setter Property="Foreground"      Value="{DynamicResource DimText}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="8"/>
      <Setter Property="CornerRadius"    Value="8"/>
      <Setter Property="Cursor"          Value="Hand"/>
    </Style>
    <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource GlassBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource MainText}"/>
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="Background"   Value="{DynamicResource GlassBg}"/>
      <Setter Property="Foreground"   Value="{DynamicResource MainText}"/>
      <Setter Property="BorderBrush"  Value="{DynamicResource BorderBrush}"/>
      <Setter Property="CornerRadius" Value="10"/>
      <Setter Property="Padding"      Value="12,8"/>
    </Style>

    <Style Selector="ToggleSwitch">
      <Setter Property="OnContent" Value=""/>
      <Setter Property="OffContent" Value=""/>
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="Auto,*,Auto">

    <!-- ══════════════════════════════════════ SIDEBAR ══════════════════════ -->
    <Border Grid.Column="0"
            IsVisible="{Binding IsSidebarOpen}"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
            Width="280">
      <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- Logo + New Chat -->
        <Border Grid.Row="0" Padding="20,24,20,16">
          <StackPanel Spacing="16">
            <StackPanel Orientation="Horizontal" Spacing="12">
              <Border Background="{DynamicResource AccentGlow}" CornerRadius="12" Width="42" Height="42">
                <TextBlock Text="G" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource NeonAccent}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Gemini Chat" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource MainText}"/>
                <TextBlock Text="Powered by Google AI" FontSize="11" Foreground="{DynamicResource SubtleText}"/>
              </StackPanel>
            </StackPanel>

            <Button Command="{Binding NewSessionCommand}"
                    Classes="primary"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="＋" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="New Chat" FontSize="14"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </Border>

        <!-- Label -->
        <Border Grid.Row="1" Padding="20,8,20,12">
          <TextBlock Text="RECENT CHATS" FontSize="11" FontWeight="Bold"
                     Foreground="{DynamicResource SubtleText}" LetterSpacing="1.2"/>
        </Border>

        <!-- Session list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding Sessions}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:ChatSession">
                <Grid ColumnDefinitions="*,Auto" Margin="12,2">
                  <Button Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Background="Transparent" BorderThickness="0"
                          Padding="12,10" Cursor="Hand"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SelectSessionCommand}"
                          CommandParameter="{Binding}">
                    <Button.Styles>
                      <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource GlassBg}"/>
                      </Style>
                    </Button.Styles>
                    <StackPanel Spacing="4">
                      <TextBlock Text="{Binding Title}" FontSize="13" Foreground="{DynamicResource MainText}"
                                 TextTrimming="CharacterEllipsis" FontWeight="Medium"/>
                      <TextBlock Text="{Binding UpdatedAt, Converter={StaticResource DateFmt}}"
                                 FontSize="11" Foreground="{DynamicResource SubtleText}"/>
                    </StackPanel>
                  </Button>
                  <Button Grid.Column="1" Classes="ghost"
                          Width="32" Height="32" Padding="4"
                          Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).DeleteSessionCommand}"
                          CommandParameter="{Binding}">
                    <TextBlock Text="×" FontSize="18" HorizontalAlignment="Center"/>
                  </Button>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <!-- Bottom Actions -->
        <Border Grid.Row="3" Padding="16,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
          <Grid ColumnDefinitions="*,Auto">
            <Button Grid.Column="0" Classes="ghost" HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left" Padding="10,8"
                    Command="{Binding ToggleSettingsCommand}">
              <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="⚙" FontSize="18" Foreground="{DynamicResource DimText}"/>
                <TextBlock Text="Settings" FontSize="14" Foreground="{DynamicResource DimText}"/>
              </StackPanel>
            </Button>
            
            <!-- Theme Toggle -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
               <TextBlock Text="🌙" FontSize="14" VerticalAlignment="Center" IsVisible="{Binding IsDarkMode}"/>
               <TextBlock Text="☀️" FontSize="14" VerticalAlignment="Center" IsVisible="{Binding !IsDarkMode}"/>
               <ToggleSwitch IsChecked="{Binding IsDarkMode}" OnContent="" OffContent=""/>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <!-- ══════════════════════════════════════ CHAT AREA ══════════════════════ -->
    <Grid Grid.Column="1" RowDefinitions="Auto,Auto,*,Auto,Auto">

      <!-- Top bar -->
      <Border Grid.Row="0" Background="{DynamicResource AppBackground}"
              BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="16,12">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <Button Grid.Column="0" Classes="ghost" Width="40" Height="40"
                  Command="{Binding ToggleSidebarCommand}">
            <TextBlock Text="☰" FontSize="18" HorizontalAlignment="Center"/>
          </Button>

          <!-- Model selector -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12"
                      HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="Model" FontSize="13" Foreground="{DynamicResource SubtleText}" VerticalAlignment="Center" FontWeight="Medium"/>
            <ComboBox ItemsSource="{Binding AvailableModels}"
                      SelectedItem="{Binding SelectedModel}"
                      MinWidth="250">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="m:GeminiModel">
                  <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,2">
                    <Border Background="{DynamicResource AccentGlow}" CornerRadius="6" Padding="6,3">
                      <TextBlock Text="{Binding Badge}" FontSize="10" FontWeight="Bold"
                                 Foreground="{DynamicResource NeonAccent}"/>
                    </Border>
                    <TextBlock Text="{Binding Name}" FontSize="14" VerticalAlignment="Center"/>
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <!-- Clear button -->
          <Button Grid.Column="2" Classes="ghost" Width="40" Height="40"
                  Command="{Binding ClearCurrentChatCommand}" ToolTip.Tip="Clear chat">
            <TextBlock Text="🗑" FontSize="18" HorizontalAlignment="Center"/>
          </Button>
        </Grid>
      </Border>

      <!-- API Key Warning -->
      <Border Grid.Row="1" IsVisible="{Binding IsApiKeyPanelVisible}"
              Background="{DynamicResource AccentGlow}" Margin="20,16,20,0"
              CornerRadius="12" BorderBrush="{DynamicResource NeonAccent}" BorderThickness="1" Padding="20">
        <StackPanel Spacing="16">
          <StackPanel Spacing="6">
            <TextBlock Text="Welcome to Gemini Chat" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource NeonAccent}"/>
            <TextBlock Text="To get started, please enter your Google Gemini API key below."
                       FontSize="13" Foreground="{DynamicResource MainText}" TextWrapping="Wrap"/>
          </StackPanel>
          
          <Grid ColumnDefinitions="*,Auto">
            <TextBox Grid.Column="0" Text="{Binding ApiKey}" PasswordChar="●" Watermark="Paste your API key here..." Margin="0,0,12,0"/>
            <Button Grid.Column="1" Classes="primary" Content="Save Key" Command="{Binding SaveApiKeyAsync}"
                    IsEnabled="{Binding !IsValidating}"/>
          </Grid>
          
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Width="8" Height="8" Fill="{Binding ApiKeyValid, Converter={StaticResource KeyColor}}"/>
            <TextBlock Text="{Binding ApiKeyStatus}" FontSize="12" Foreground="{DynamicResource DimText}"/>
            <TextBlock Text="•" Foreground="{DynamicResource SubtleText}" Margin="4,0"/>
            <Button Classes="ghost" Padding="0" Content="Get a key from Google AI Studio"
                    Foreground="{DynamicResource NeonAccent}" FontSize="12" Cursor="Hand"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Messages -->
      <ScrollViewer Grid.Row="2" x:Name="ChatScroll" Padding="20,10">
        <StackPanel Spacing="24">
          <!-- Icebreakers -->
          <ItemsControl ItemsSource="{Binding IcebreakerTiles}"
                        IsVisible="{Binding CurrentSession.Messages.Count, Converter={StaticResource IntVis}}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel HorizontalAlignment="Center" Margin="0,40,0,0"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Button Classes="ghost" Margin="8" Width="200" Height="120"
                        Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).SendIcebreakerCommand}"
                        CommandParameter="{Binding}">
                  <Border Background="{DynamicResource GlassBg}" CornerRadius="16" Padding="16"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                      <TextBlock Text="{Binding Icon}" FontSize="24"/>
                      <TextBlock Text="{Binding Label}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </Button>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Message List -->
          <ItemsControl ItemsSource="{Binding CurrentSession.Messages}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:ChatMessage">
                <Grid Margin="0,4" HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                  <StackPanel Spacing="6" MaxWidth="850">
                    <StackPanel Orientation="Horizontal" Spacing="10"
                                HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                      <Border Width="28" Height="28" CornerRadius="14"
                              Background="{Binding IsUser, Converter={StaticResource AvatarBrush}}"
                              IsVisible="{Binding !IsUser}">
                        <TextBlock Text="{Binding IsUser, Converter={StaticResource AvatarText}}"
                                   FontSize="12" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock Text="{Binding Role}" FontSize="11" FontWeight="Bold"
                                 Foreground="{DynamicResource SubtleText}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border CornerRadius="16" Padding="16,12"
                            Background="{Binding Role, Converter={StaticResource RoleBubble}}"
                            BoxShadow="0 4 12 0 #10000000">
                      <ctrl:MarkdownViewer Markdown="{Binding Content}"/>
                    </Border>
                    
                    <StackPanel Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="{Binding Role, Converter={StaticResource RoleAlign}}">
                       <Ellipse Width="6" Height="6" Fill="{Binding Status, Converter={StaticResource StatusColor}}"
                                IsVisible="{Binding IsStreaming}"/>
                       <TextBlock Text="{Binding Timestamp, Converter={StaticResource DateFmt}}"
                                  FontSize="10" Foreground="{DynamicResource SubtleText}"/>
                    </StackPanel>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- Input Area -->
      <Border Grid.Row="3" Padding="24,12,24,24" Background="Transparent">
        <Grid ColumnDefinitions="*,Auto">
          <TextBox Grid.Column="0"
                   Text="{Binding UserInput}"
                   Watermark="Ask Gemini anything..."
                   AcceptsReturn="True"
                   TextWrapping="Wrap"
                   MaxHeight="200"
                   MinHeight="56"
                   VerticalContentAlignment="Center"
                   FontSize="14"
                   Padding="16,14">
            <TextBox.KeyBindings>
              <KeyBinding Gesture="Enter" Command="{Binding SendMessageCommand}"/>
            </TextBox.KeyBindings>
          </TextBox>
          
          <Button Grid.Column="1" Classes="primary"
                  Width="56" Height="56" Margin="12,0,0,0"
                  Command="{Binding SendMessageCommand}"
                  IsVisible="{Binding !IsLoading}">
            <TextBlock Text="↑" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
          </Button>
          
          <Button Grid.Column="1" Classes="primary"
                  Width="56" Height="56" Margin="12,0,0,0"
                  Command="{Binding StopGenerationCommand}"
                  IsVisible="{Binding IsLoading}"
                  Background="#EF4444">
            <TextBlock Text="■" FontSize="18" HorizontalAlignment="Center"/>
          </Button>
        </Grid>
      </Border>

      <!-- Status bar -->
      <Border Grid.Row="4" Padding="16,4" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
        <TextBlock Text="{Binding StatusMessage}" FontSize="10" Foreground="{DynamicResource SubtleText}"/>
      </Border>
    </Grid>

    <!-- ══════════════════════════════════════ SETTINGS PANEL ════════════════ -->
    <Border Grid.Column="2"
            IsVisible="{Binding IsSettingsOpen}"
            Background="{DynamicResource SidebarBackground}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
            Width="320">
      <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Padding="20,24,20,16">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"/>
            <Button Grid.Column="1" Classes="ghost" Command="{Binding ToggleSettingsCommand}">
              <TextBlock Text="×" FontSize="24"/>
            </Button>
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Padding="20,0">
          <StackPanel Spacing="24">
            <!-- Model Config -->
            <StackPanel Spacing="12">
              <TextBlock Text="Generation Config" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NeonAccent}"/>
              
              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Temperature" FontSize="13"/>
                  <TextBlock Grid.Column="1" Text="{Binding Temperature, StringFormat=\{0:F1\}}" FontSize="12" Foreground="{DynamicResource DimText}"/>
                </Grid>
                <Slider Minimum="0" Maximum="2" Value="{Binding Temperature}" SmallChange="0.1" LargeChange="0.2"/>
              </StackPanel>

              <StackPanel Spacing="6">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="Max Tokens" FontSize="13"/>
                  <TextBlock Grid.Column="1" Text="{Binding MaxTokens}" FontSize="12" Foreground="{DynamicResource DimText}"/>
                </Grid>
                <Slider Minimum="1" Maximum="128000" Value="{Binding MaxTokens}"/>
              </StackPanel>

              <ToggleSwitch IsChecked="{Binding EnableStreaming}" Content="Enable Streaming" FontSize="13"/>
            </StackPanel>

            <!-- System Prompt -->
            <StackPanel Spacing="12">
              <TextBlock Text="System Instructions" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NeonAccent}"/>
              <TextBox Text="{Binding SystemPrompt}" AcceptsReturn="True" TextWrapping="Wrap" Height="120" FontSize="13" Watermark="Enter system instructions..."/>
            </StackPanel>

            <!-- API Key -->
            <StackPanel Spacing="12">
              <TextBlock Text="API Management" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource NeonAccent}"/>
              <Button Classes="ghost" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Command="{Binding ShowApiKeyPanel}">
                <StackPanel Orientation="Horizontal" Spacing="10">
                  <TextBlock Text="🔑" FontSize="14"/>
                  <TextBlock Text="Update API Key" FontSize="13"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="20" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
          <Button Classes="primary" Content="Save Changes" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding SaveSettingsCommand}"/>
        </Border>
      </Grid>
    </Border>
  </Grid>
</Window>
