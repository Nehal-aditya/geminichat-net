<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="GeminiChat.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <!-- Neon Glass Dark Palette -->
          <SolidColorBrush x:Key="AppBackground" Color="#080D1A"/>
          <SolidColorBrush x:Key="SidebarBackground" Color="#060B16"/>
          <SolidColorBrush x:Key="BorderBrush" Color="#1E293B"/>
          <SolidColorBrush x:Key="MainText" Color="#E2E8F0"/>
          <SolidColorBrush x:Key="DimText" Color="#94A3B8"/>
          <SolidColorBrush x:Key="SubtleText" Color="#475569"/>
          
          <SolidColorBrush x:Key="AccentColor" Color="#3B82F6"/>
          <SolidColorBrush x:Key="AccentGlow" Color="#403B82F6"/>
          <SolidColorBrush x:Key="NeonAccent" Color="#60A5FA"/>
          
          <SolidColorBrush x:Key="UserBubbleBg" Color="#2563EB"/>
          <SolidColorBrush x:Key="AssistantBubbleBg" Color="#1E293B"/>
          
          <SolidColorBrush x:Key="CodeBg" Color="#0F172A"/>
          <SolidColorBrush x:Key="CodeBorder" Color="#334155"/>
          <SolidColorBrush x:Key="CodeFg" Color="#7DD3FC"/>
          
          <SolidColorBrush x:Key="GlassBg" Color="#1AFFFFFF"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#33FFFFFF"/>
        </ResourceDictionary>
        
        <ResourceDictionary x:Key="Light">
          <!-- Neon Glass Light Palette -->
          <SolidColorBrush x:Key="AppBackground" Color="#F8FAFC"/>
          <SolidColorBrush x:Key="SidebarBackground" Color="#F1F5F9"/>
          <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
          <SolidColorBrush x:Key="MainText" Color="#1E293B"/>
          <SolidColorBrush x:Key="DimText" Color="#64748B"/>
          <SolidColorBrush x:Key="SubtleText" Color="#94A3B8"/>
          
          <SolidColorBrush x:Key="AccentColor" Color="#2563EB"/>
          <SolidColorBrush x:Key="AccentGlow" Color="#202563EB"/>
          <SolidColorBrush x:Key="NeonAccent" Color="#3B82F6"/>
          
          <SolidColorBrush x:Key="UserBubbleBg" Color="#3B82F6"/>
          <SolidColorBrush x:Key="AssistantBubbleBg" Color="#E2E8F0"/>
          
          <SolidColorBrush x:Key="CodeBg" Color="#F1F5F9"/>
          <SolidColorBrush x:Key="CodeBorder" Color="#CBD5E1"/>
          <SolidColorBrush x:Key="CodeFg" Color="#0369A1"/>
          
          <SolidColorBrush x:Key="GlassBg" Color="#1A000000"/>
          <SolidColorBrush x:Key="GlassBorder" Color="#33000000"/>
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>
</Application>
